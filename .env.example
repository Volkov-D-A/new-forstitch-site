RESTART_POLICY=unless-stopped
DOCKERHUB_USER=
APP_VERSION=dev

HEALTHCHECK_INTERVAL=5s
HEALTHCHECK_TIMEOUT=5s
HEALTHCHECK_RETRIES=10

POSTGRES_IMAGE=postgres
POSTGRES_IMAGE_VERSION=16-alpine
POSTGRES_CONTAINER_NAME=forstitch-postgres
POSTGRES_DB=forstitch
POSTGRES_USER=forstitch
POSTGRES_PASSWORD=forstitch
POSTGRES_PORT=5432

MINIO_IMAGE=quay.io/minio/minio
MINIO_IMAGE_VERSION=latest
MINIO_MC_IMAGE=quay.io/minio/mc
MINIO_MC_IMAGE_VERSION=latest
MINIO_CONTAINER_NAME=forstitch-minio
MINIO_ROOT_USER=forstitch
MINIO_ROOT_PASSWORD=forstitch-secret
MINIO_BUCKET=forstitch
MINIO_API_PORT=9000
MINIO_API_INTERNAL_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_CONSOLE_INTERNAL_PORT=9001

MAILPIT_IMAGE=axllent/mailpit
MAILPIT_IMAGE_VERSION=latest
MAILPIT_CONTAINER_NAME=forstitch-mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_SMTP_INTERNAL_PORT=1025
MAILPIT_WEB_PORT=8025
MAILPIT_WEB_INTERNAL_PORT=8025

DATABASE_URL=postgres://forstitch:forstitch@localhost:5432/forstitch?sslmode=disable
ADMIN_USERNAME=dimas
ADMIN_PASSWORD=dimas
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=forstitch
MINIO_SECRET_KEY=forstitch-secret
MINIO_USE_SSL=false
FILE_BASE_URL=http://localhost:3000/api/files
APP_BASE_URL=http://localhost:3000
MAIL_ENABLED=true
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@forstitch.local
MAIL_FROM_NAME=Forstitch
