# Application images
DOCKERHUB_USER=your-dockerhub-user
APP_VERSION=1.0.0

# Infrastructure images
CADDY_VERSION=2-alpine
POSTGRES_VERSION=16-alpine
MINIO_VERSION=latest

# Public addresses
APP_DOMAIN=forstitch.ru
APP_BASE_URL=https://forstitch.ru
FILE_BASE_URL=https://forstitch.ru/api/files
CORS_ALLOWED_ORIGINS=https://forstitch.ru

# PostgreSQL
POSTGRES_DB=forstitch
POSTGRES_USER=forstitch
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgres://forstitch:replace-with-a-long-random-password@postgres:5432/forstitch?sslmode=disable

# MinIO
MINIO_ROOT_USER=replace-with-a-minio-access-key
MINIO_ROOT_PASSWORD=replace-with-a-long-random-secret
MINIO_BUCKET=forstitch

# Initial application administrator
ADMIN_USERNAME=replace-with-admin-login
ADMIN_PASSWORD=replace-with-a-long-random-password

# SMTP
MAIL_ENABLED=true
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=replace-with-smtp-login
MAIL_PASSWORD=replace-with-smtp-password
MAIL_FROM=no-reply@forstitch.ru
MAIL_FROM_NAME=Forstitch
